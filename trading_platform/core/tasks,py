@shared_task
def fetch_market_data():
    for instrument in Instrument.objects.all():
        # call an external API here; this example uses dummy data
        # Suppose we fetch price and save or broadcast it
        price = fetch_latest_price(instrument)  # Now uses our new function!
        # store to DB or cache ...
        print(f"Fetched {instrument.symbol} price: {price}")
        
@shared_task
def broadcast_prices():
    channel_layer = get_channel_layer()
    for instrument in Instrument.objects.all():
        price = fetch_latest_price(instrument)  # Now uses our new function!
        async_to_sync(channel_layer.group_send)(
            'prices',
            {'type': 'send_price', 'data': {'symbol': instrument.symbol, 'price': price}}
        )