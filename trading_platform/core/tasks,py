def fetch_latest_price(instrument):
    """
    Takes an Instrument from the database and returns its current live price.
    """
    # ---------------------------------------------------------
    # OPTION 1: SIMULATED DATA (For testing the dashboard)
    # ---------------------------------------------------------
    # We assign realistic base prices depending on the asset class
    base_prices = {
        'crypto': 68000.00,  # BTC ballpark
        'stock': 180.00,     # AAPL ballpark
        'forex': 1.08        # EUR/USD ballpark
    }
    
    base = base_prices.get(instrument.asset_class, 100.00)
    
    # Make the price randomly jump up or down by a tiny fraction (max 0.5%)
    fluctuation = base * random.uniform(-0.005, 0.005)
    return round(base + fluctuation, 2)

